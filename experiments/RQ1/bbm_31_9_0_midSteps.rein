// Synchronous dynamics
directive updates sync;

// Default regulation conditions
directive regulation legacy;

v_ACE2[-+] (0..17); v_CLN3[-+] (0..17); v_HCM1[-+] (0..17); v_MBF[-+] (0..17); v_SBF[-+] (0..17); v_SFF[-+] (0..17); v_SWI5[-+] (0..17); v_YHP1[-+] (0..17); v_YOX1[-+] (0..17);

v_SFF v_SWI5 positive optional;
v_SWI5 v_CLN3 positive optional;
v_ACE2 v_CLN3 positive optional;
v_YHP1 v_CLN3 negative optional;
v_YOX1 v_CLN3 negative optional;
v_SBF v_YOX1 positive optional;
v_MBF v_YOX1 positive optional;
v_YHP1 v_SBF negative optional;
v_CLN3 v_SBF positive optional;
v_MBF v_SBF positive optional;
v_YOX1 v_SBF negative optional;
v_SFF v_ACE2 positive optional;
v_SBF v_HCM1 positive optional;
v_MBF v_HCM1 positive optional;
v_SBF v_YHP1 positive optional;
v_MBF v_YHP1 positive optional;
v_SBF v_SFF positive optional;
v_HCM1 v_SFF positive optional;
v_CLN3 v_MBF positive optional;


